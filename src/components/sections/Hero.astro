---
import GitHub from "../icons/GitHub.astro";
import LinkedIn from "../icons/LinkedIn.astro";
import Twitter from "../icons/Twitter.astro";
import ArrowDown from "../icons/ArrowDown.astro";
import { github, linkedin, twitter, location } from "../../data/info.ts";

const resumeUrl = "/my-resume.pdf";

const info = [
  { label: "Based in", value: location },
  { label: "Focus", value: "React, Node.js & React Native" },
  { label: "Available for", value: "Full-time & freelance work" },
];

const socials = [
  { name: "GitHub", href: github, Icon: GitHub },
  { name: "LinkedIn", href: linkedin, Icon: LinkedIn },
  { name: "X", href: twitter, Icon: Twitter },
];
---

<section
  class="border-b border-[var(--border)]"
>
  <div
    class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-20 md:py-28 grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-start"
  >
    <!-- Left column -->
    <div class="flex flex-col gap-6">
      <span
        class="inline-flex w-fit items-center rounded-full bg-[var(--accent-subtle)] text-[var(--accent)] text-sm px-3 py-1"
      >
        Available for work
      </span>

      <h1
        class="font-serif text-5xl md:text-6xl leading-[1.1] tracking-tight text-[var(--text-1)]"
      >
        Full stack developer building clean, fast products.
      </h1>

      <p class="text-lg text-[var(--text-2)] max-w-[var(--max-w-content)]">
        I'm Sandeep Singh — a full stack and mobile developer.
      </p>

      <p
        class="text-base text-[var(--text-2)] max-w-[var(--max-w-content)] leading-[var(--leading-normal)]"
      >
        I design and ship end-to-end web and mobile applications, from the
        database to the pixel. I care about fast load times, clean interfaces,
        and code that's easy to live with.
      </p>

      <a
        href="#work"
        class="link-arrow group inline-flex w-fit items-center gap-1.5 text-[var(--accent)] hover:text-[var(--accent-hover)] text-base mt-2"
      >
        View my work
        <span
          class="transition-transform duration-200 group-hover:translate-x-1"
          aria-hidden="true">&rarr;</span
        >
      </a>
    </div>

    <!-- Right column — info panel -->
    <div class="flex flex-col">
      {
        info.map((row, i) => (
          <div
            class:list={[
              "flex flex-col gap-1 py-4",
              { "border-t border-[var(--border)]": i !== 0 },
            ]}
          >
            <span class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]">
              {row.label}
            </span>
            <span class="text-base text-[var(--text-1)]">{row.value}</span>
          </div>
        ))
      }

      <!-- Resume CTA + social links -->
      <div class="flex flex-col gap-5 border-t border-[var(--border)] pt-6 mt-1">
        <a
          href={resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="resume-cta group inline-flex w-full items-center justify-center gap-2 rounded-[var(--border-radius-md)] bg-[var(--accent)] px-5 py-3 text-base font-medium text-[var(--bg)]! shadow-[var(--shadow)] transition-colors duration-200 hover:bg-[var(--accent-hover)]"
        >
          <span
            class="transition-transform duration-200 group-hover:translate-y-0.5"
            aria-hidden="true"><ArrowDown /></span
          >
          View resume
        </a>

        <div class="flex items-center gap-2">
          <span class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)] mr-1">
            Find me
          </span>
          {
            socials.map(({ name, href, Icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={name}
                class="hero-social text-[var(--text-3)] transition-colors duration-200 hover:text-[var(--text-1)]"
              >
                <Icon />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Heroicons ship at 24px (size-6); hero social icons should be 20px */
  .hero-social :global(svg) {
    width: 20px;
    height: 20px;
  }
  /* Resume icon sized to match the button text */
  .resume-cta :global(svg) {
    width: 18px;
    height: 18px;
  }
</style>
