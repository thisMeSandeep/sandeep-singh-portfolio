---
import { blogs } from "../../data/blogs.ts";
import BlogCard from "../ui/BlogCard.astro";

const latest = blogs.slice(0, 3);
---

<section id="blog" class="border-b border-[var(--border)]">
  <div class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      Latest Writing
    </span>

    <div class="flex items-baseline justify-between gap-4 mt-3">
      <h2
        class="font-serif text-2xl leading-tight tracking-tight text-[var(--text-1)]"
      >
        From the blog
      </h2>
      <a
        href="/blog"
        class="link-arrow group inline-flex shrink-0 items-center gap-1.5 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)]"
      >
        Read all articles
        <span
          class="transition-transform duration-200 group-hover:translate-x-1"
          aria-hidden="true">&rarr;</span
        >
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-10">
      {
        latest.map((post) => (
          <BlogCard
            title={post.title}
            excerpt={post.excerpt}
            publishedDate={post.publishedDate}
            slug={post.slug}
          />
        ))
      }
    </div>
  </div>
</section>
