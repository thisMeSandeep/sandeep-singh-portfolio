---
import { about } from "../../data/content.ts";
---

<section id="about" class="border-b border-[var(--border)]">
  <div
    class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24 grid grid-cols-1 md:grid-cols-[45fr_55fr] gap-12 md:gap-16 items-start"
  >
    <!-- Left column -->
    <div class="flex flex-col gap-5">
      <span
        class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
      >
        {about.eyebrow}
      </span>
      <h2
        class="font-serif text-3xl leading-tight tracking-tight text-[var(--text-1)]"
      >
        {about.heading}
      </h2>
    </div>

    <!-- Right column -->
    <div class="flex flex-col gap-5">
      {
        about.paragraphs.map((p) => (
          <p class="text-base text-[var(--text-2)] leading-[var(--leading-relaxed)]">
            {p}
          </p>
        ))
      }
      <a
        href={about.ctaHref}
        class="link-arrow group inline-flex w-fit items-center gap-1.5 text-[var(--accent)] hover:text-[var(--accent-hover)] text-base mt-1"
      >
        {about.ctaLabel}
        <span
          class="transition-transform duration-200 group-hover:translate-x-1"
          aria-hidden="true">&rarr;</span
        >
      </a>
    </div>
  </div>
</section>
