---
import TechIcon from "../ui/TechIcon.astro";

const groups = [
  {
    label: "Frontend",
    items: [
      { name: "React", icon: "React" },
      { name: "Next.js", icon: "Next.js" },
      { name: "TypeScript", icon: "TypeScript" },
      { name: "JavaScript", icon: "JavaScript" },
      { name: "Redux", icon: "Redux" },
      { name: "Tailwind CSS", icon: "Tailwind CSS" },
      { name: "HTML5", icon: "HTML5" },
      { name: "CSS3", icon: "CSS3" },
    ],
  },
  {
    label: "Backend",
    items: [
      { name: "Node.js", icon: "Node.js" },
      { name: "Express", icon: "Express" },
      { name: "Hono", icon: "Hono" },
      { name: "FastAPI", icon: "FastAPI" },
      { name: "Python", icon: "Python" },
      { name: "PostgreSQL", icon: "PostgresSQL" },
      { name: "MongoDB", icon: "MongoDB" },
      { name: "Mongoose", icon: "Mongoose.js" },
    ],
  },
  {
    label: "Mobile",
    items: [
      { name: "React Native", icon: "React" },
      { name: "Firebase", icon: "Firebase" },
      { name: "Appwrite", icon: "Appwrite" },
      { name: "Socket.io", icon: "Socket.io" },
    ],
  },
  {
    label: "Tools & DevOps",
    items: [
      { name: "Git", icon: "Git" },
      { name: "Docker", icon: "Docker" },
      { name: "Bash", icon: "Bash" },
      { name: "Jest", icon: "Jest" },
      { name: "Bun", icon: "Bun" },
      { name: "Astro", icon: "Astro" },
    ],
  },
];
---

<section id="skills" class="border-b border-[var(--border)]">
  <div class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      Skills
    </span>
    <h2
      class="font-serif text-2xl leading-tight tracking-tight text-[var(--text-1)] mt-3"
    >
      Tools I reach for
    </h2>

    <div class="flex flex-col gap-10 mt-10">
      {
        groups.map((group) => (
          <div class="flex flex-col gap-5">
            <span class="text-xs uppercase tracking-[var(--tracking-wide)] text-[var(--text-3)]">
              {group.label}
            </span>
            <div class="flex flex-wrap gap-x-8 gap-y-6">
              {group.items.map((item) => (
                <TechIcon name={item.name} icon={item.icon} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
