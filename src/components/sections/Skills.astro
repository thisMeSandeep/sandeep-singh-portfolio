---
import TechIcon from "../ui/TechIcon.astro";

const groups: {
  label: string;
  items: { name: string; icon: string; invert?: "dark" | "light" }[];
}[] = [
  {
    label: "Frontend",
    items: [
      { name: "React", icon: "React" },
      { name: "Next.js", icon: "Next.js", invert: "dark" },
      { name: "TanStack Start", icon: "tanstack" },
      { name: "Astro", icon: "Astro" },
      { name: "TypeScript", icon: "TypeScript" },
      { name: "JavaScript", icon: "JavaScript" },
      { name: "Redux", icon: "Redux" },
      { name: "Zustand", icon: "zustand" },
      { name: "Tailwind CSS", icon: "Tailwind CSS" },
      { name: "shadcn/ui", icon: "shadcn-ui", invert: "light" },
      { name: "Framer Motion", icon: "framer-dark", invert: "light" },
      { name: "HTML5", icon: "HTML5" },
      { name: "CSS3", icon: "CSS3" },
    ],
  },
  {
    label: "Backend",
    items: [
      { name: "Node.js", icon: "Node.js" },
      { name: "Python", icon: "Python" },
      { name: "Express", icon: "Express", invert: "dark" },
      { name: "Hono", icon: "Hono" },
      { name: "FastAPI", icon: "FastAPI" },
      { name: "Better Auth", icon: "better-auth" },
      { name: "AI SDK", icon: "ai-sdk", invert: "dark" },
      { name: "LangChain", icon: "langchain-color" },
      { name: "PostgreSQL", icon: "PostgresSQL" },
      { name: "MongoDB", icon: "MongoDB" },
      { name: "Redis", icon: "redis" },
      { name: "Mongoose", icon: "Mongoose.js" },
      { name: "Prisma", icon: "prisma", invert: "light" },
      { name: "Drizzle ORM", icon: "drizzle-orm" },
    ],
  },
  {
    label: "Mobile",
    items: [
      { name: "React Native", icon: "reactnative" },
      { name: "Expo", icon: "expo" },
      { name: "Firebase", icon: "Firebase" },
      { name: "Appwrite", icon: "Appwrite" },
      { name: "Socket.io", icon: "Socket.io", invert: "dark" },
    ],
  },
  {
    label: "Tools & DevOps",
    items: [
      { name: "Git", icon: "Git" },
      { name: "Docker", icon: "Docker" },
      { name: "AWS", icon: "aws" },
      { name: "Nginx", icon: "nginx" },
      { name: "Linux", icon: "linux" },
      { name: "Bash", icon: "Bash" },
      { name: "Jest", icon: "Jest" },
      { name: "Bun", icon: "Bun" },
    ],
  },
];
---

<section id="skills" class="border-b border-[var(--border)]">
  <div class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      Skills
    </span>
    <h2
      class="font-serif text-2xl leading-tight tracking-tight text-[var(--text-1)] mt-3"
    >
      Tools I reach for
    </h2>

    <div class="flex flex-col gap-10 mt-10">
      {
        groups.map((group) => (
          <div class="flex flex-col gap-5">
            <span class="text-xs uppercase tracking-[var(--tracking-wide)] text-[var(--text-3)]">
              {group.label}
            </span>
            <div class="flex flex-wrap gap-x-8 gap-y-6">
              {group.items.map((item) => (
                <TechIcon name={item.name} icon={item.icon} invert={item.invert} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
