---
import { Image } from "astro:assets";
import Phone from "../icons/Phone.astro";
import Mail from "../icons/Mail.astro";
import Message from "../icons/Message.astro";
import { phone, email, dropFormLink } from "../../data/info.ts";
import qrcode from "../../assets/qrcode.png";

// info.ts stores the `tel:` / `mailto:` hrefs; strip the scheme for display.
const phoneDisplay = phone.replace(/^tel:/, "");
const emailDisplay = email.replace(/^mailto:/, "");

const rows = [
  {
    Icon: Phone,
    label: "Phone",
    value: phoneDisplay,
    href: phone,
  },
  {
    Icon: Mail,
    label: "Email",
    value: emailDisplay,
    href: email,
  },
  {
    Icon: Message,
    label: "Project enquiry",
    value: "Start a project",
    href: dropFormLink,
    arrow: true,
    external: true,
  },
];
---

<section id="contact">
  <div class="mx-auto max-w-[var(--max-w-layout)] px-6 md:px-8 py-24">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      Contact
    </span>
    <h2
      class="font-serif text-3xl leading-tight tracking-tight text-[var(--text-1)] mt-3"
    >
      Let's work together.
    </h2>
    <p class="text-base text-[var(--text-2)] mt-3 max-w-[var(--max-w-content)]">
      Have a project in mind, or just want to say hello? The fastest way to
      reach me is below.
    </p>

    <ul class="flex flex-col mt-10">
      {
        rows.map(({ Icon, label, value, href, arrow, external }) => (
          <li>
            <a
              href={href}
              {...(external
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
              class="group grid grid-cols-[1.25rem_5rem_minmax(0,1fr)] items-center gap-4 py-4 border-b border-[var(--border-subtle)] transition-colors duration-200 sm:grid-cols-[1.25rem_8rem_minmax(0,1fr)]"
            >
              <span class="contact-icon text-[var(--text-3)]">
                <Icon />
              </span>
              <span class="text-sm text-[var(--text-3)]">
                {label}
              </span>
              <span class="inline-flex min-w-0 flex-wrap items-center gap-1.5 break-all text-base text-[var(--text-1)] transition-colors duration-200 group-hover:text-[var(--accent)]">
                {value}
                {arrow && (
                  <span
                    class="transition-transform duration-200 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    &rarr;
                  </span>
                )}
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div
      class="mt-10 flex flex-col items-center gap-5 rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] bg-[var(--bg)] p-6 sm:flex-row sm:items-center sm:gap-6"
    >
      <a
        href={dropFormLink}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 rounded-[var(--border-radius)] border border-[var(--border-subtle)] bg-white p-2"
      >
        <Image
          src={qrcode}
          alt="QR code linking to the project enquiry form"
          width={200}
          height={200}
          class="h-28 w-28"
        />
      </a>
      <div class="text-center sm:text-left">
        <p class="text-base text-[var(--text-1)]">
          Prefer to scan? Point your camera at the code.
        </p>
        <p
          class="mt-1.5 text-sm text-[var(--text-2)] max-w-[var(--max-w-content)]"
        >
          It opens a short form where you can message me directly.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Heroicons ship at 24px (size-6); contact icons should be 20px */
  .contact-icon :global(svg) {
    width: 20px;
    height: 20px;
  }
</style>
