---
import Phone from "../icons/Phone.astro";
import Mail from "../icons/Mail.astro";
import Message from "../icons/Message.astro";
import { phone, email } from "../../data/info.ts";

// info.ts stores the `tel:` / `mailto:` hrefs; strip the scheme for display.
const phoneDisplay = phone.replace(/^tel:/, "");
const emailDisplay = email.replace(/^mailto:/, "");

const rows = [
  {
    Icon: Phone,
    label: "Phone",
    value: phoneDisplay,
    href: phone,
  },
  {
    Icon: Mail,
    label: "Email",
    value: emailDisplay,
    href: email,
  },
  {
    Icon: Message,
    label: "Project enquiry",
    value: "Start a project",
    href: "https://dropform.io",
    arrow: true,
    external: true,
  },
];
---

<section id="contact">
  <div class="mx-auto max-w-[var(--max-w-layout)] px-6 md:px-8 py-24">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      Contact
    </span>
    <h2
      class="font-serif text-3xl leading-tight tracking-tight text-[var(--text-1)] mt-3"
    >
      Let's work together.
    </h2>
    <p class="text-base text-[var(--text-2)] mt-3 max-w-[var(--max-w-content)]">
      Have a project in mind, or just want to say hello? The fastest way to
      reach me is below.
    </p>

    <ul class="flex flex-col mt-10">
      {
        rows.map(({ Icon, label, value, href, arrow, external }) => (
          <li>
            <a
              href={href}
              {...(external
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
              class="group flex items-center gap-4 py-4 border-b border-[var(--border-subtle)] transition-colors duration-200"
            >
              <span class="contact-icon text-[var(--text-3)]">
                <Icon />
              </span>
              <span class="text-sm text-[var(--text-3)] w-32 shrink-0">
                {label}
              </span>
              <span class="inline-flex items-center gap-1.5 text-base text-[var(--text-1)] transition-colors duration-200 group-hover:text-[var(--accent)]">
                {value}
                {arrow && (
                  <span
                    class="transition-transform duration-200 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    &rarr;
                  </span>
                )}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  /* Heroicons ship at 24px (size-6); contact icons should be 20px */
  .contact-icon :global(svg) {
    width: 20px;
    height: 20px;
  }
</style>
