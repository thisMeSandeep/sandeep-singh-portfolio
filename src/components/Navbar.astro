---
import Sun from "./icons/Sun.astro";
import Moon from "./icons/Moon.astro";
import Menu from "./icons/Menu.astro";
import Close from "./icons/Close.astro";

const links = [
  { label: "Work", href: "#work" },
  { label: "Blog", href: "#blog" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];
---

<header
  id="navbar"
  class="nav sticky top-0 z-50 bg-[var(--bg)] border-b border-[var(--border-subtle)] transition-[background,backdrop-filter,border-color] duration-200"
>
  <div
    class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-4 flex items-center justify-between"
  >
    <!-- Logo / name -->
    <a
      href="#"
      class="font-serif text-lg tracking-tight text-[var(--text-1)] hover:text-[var(--text-1)]"
      >Sandeep Singh</a
    >

    <!-- Desktop nav links -->
    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {
        links.map((link) =>
          link.label === "Contact" ? (
            <a
              href={link.href}
              class="text-sm text-[var(--text-1)] border-b border-[var(--text-1)] pb-0.5 transition-colors duration-200"
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class="text-sm text-[var(--text-3)] hover:text-[var(--text-1)] transition-colors duration-200"
            >
              {link.label}
            </a>
          )
        )
      }

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="icon-btn inline-flex items-center justify-center text-[var(--text-3)] hover:text-[var(--text-1)] transition-colors duration-200 cursor-pointer"
      >
        <span class="icon-sun"><Sun /></span>
        <span class="icon-moon"><Moon /></span>
      </button>
    </nav>

    <!-- Mobile controls -->
    <div class="flex md:hidden items-center gap-3">
      <button
        id="theme-toggle-mobile"
        type="button"
        aria-label="Toggle dark mode"
        class="icon-btn inline-flex items-center justify-center text-[var(--text-3)] hover:text-[var(--text-1)] transition-colors duration-200 cursor-pointer"
      >
        <span class="icon-sun"><Sun /></span>
        <span class="icon-moon"><Moon /></span>
      </button>
      <button
        id="menu-open"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-overlay"
        class="icon-btn inline-flex items-center justify-center text-[var(--text-3)] hover:text-[var(--text-1)] transition-colors duration-200 cursor-pointer"
      >
        <Menu />
      </button>
    </div>
  </div>

  <!-- Mobile overlay -->
  <div
    id="mobile-overlay"
    aria-hidden="true"
    class="mobile-overlay fixed inset-0 z-60 bg-[var(--bg)] px-6 flex-col"
  >
    <div
      class="flex items-center justify-between py-4 border-b border-[var(--border-subtle)]"
    >
      <span class="font-serif text-lg tracking-tight text-[var(--text-1)]"
        >Sandeep Singh</span
      >
      <button
        id="menu-close"
        type="button"
        aria-label="Close menu"
        class="icon-btn inline-flex items-center justify-center text-[var(--text-3)] hover:text-[var(--text-1)] transition-colors duration-200 cursor-pointer"
      >
        <Close />
      </button>
    </div>
    <nav class="flex flex-col gap-2 mt-10" aria-label="Mobile">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-mobile-link
            class="font-serif text-3xl text-[var(--text-1)] hover:text-[var(--accent)] py-2 transition-colors duration-200"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  /* Scrolled state — backdrop blur (toggled by JS). Not expressible as a
     plain utility without the dark variant / arbitrary backdrop juggling. */
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Normalise the fixed 24px icons down to 20px */
  .icon-btn :global(svg) {
    width: 20px;
    height: 20px;
  }

  /* Theme icon swap — keyed off the .dark ancestor (no `dark:` variant configured) */
  .icon-sun {
    display: none;
  }
  .icon-moon {
    display: inline-flex;
  }
  :global(.dark) .icon-sun {
    display: inline-flex;
  }
  :global(.dark) .icon-moon {
    display: none;
  }

  /* Overlay visibility toggle */
  .mobile-overlay {
    display: none;
  }
  .mobile-overlay.open {
    display: flex;
  }
</style>

<script is:inline>
  (function () {
    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }
    document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
    document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);

    const nav = document.getElementById("navbar");
    function onScroll() {
      if (window.scrollY > 8) nav?.classList.add("scrolled");
      else nav?.classList.remove("scrolled");
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    const overlay = document.getElementById("mobile-overlay");
    const openBtn = document.getElementById("menu-open");
    const closeBtn = document.getElementById("menu-close");
    function openMenu() {
      overlay?.classList.add("open");
      overlay?.setAttribute("aria-hidden", "false");
      openBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }
    function closeMenu() {
      overlay?.classList.remove("open");
      overlay?.setAttribute("aria-hidden", "true");
      openBtn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }
    openBtn?.addEventListener("click", openMenu);
    closeBtn?.addEventListener("click", closeMenu);
    document
      .querySelectorAll("[data-mobile-link]")
      .forEach((l) => l.addEventListener("click", closeMenu));
  })();
</script>
