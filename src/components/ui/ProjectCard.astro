---
import { Image } from "astro:assets";

interface Props {
  title: string;
  tagline: string;
  category: string;
  cover: string;
  tech: string[];
  liveUrl?: string;
  githubUrl?: string;
  slug: string;
  bentoSize: "large" | "medium" | "small";
}

const { title, tagline, category, cover, tech, slug } = Astro.props;
---

<article
  class="project-card group flex h-full flex-col overflow-hidden rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] bg-[var(--bg)] transition-[border-color,box-shadow] duration-200 hover:border-[var(--border-strong)] hover:shadow-[var(--shadow)]"
>
  <!-- Image fills the remaining height of the cell -->
  <a
    href={`/projects/${slug}`}
    class="relative block min-h-44 w-full grow overflow-hidden lg:min-h-0"
  >
    <Image
      src={cover}
      alt={title}
      width={1200}
      height={800}
      class="absolute inset-0 h-full w-full border-b border-[var(--border-subtle)] object-cover transition-transform duration-300 group-hover:scale-[1.03]"
    />
  </a>

  <!-- Body: fixed, compact -->
  <div class="flex shrink-0 flex-col gap-2 p-5">
    <span
      class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
    >
      {category}
    </span>

    <a href={`/projects/${slug}`}>
      <h3
        class="font-serif text-xl font-medium leading-snug text-[var(--text-1)] transition-colors duration-200 group-hover:text-[var(--accent)]"
      >
        {title}
      </h3>
    </a>

    <p class="line-clamp-2 text-sm text-[var(--text-2)] leading-[var(--leading-normal)]">
      {tagline}
    </p>

    <div class="mt-1 flex flex-wrap gap-2">
      {
        tech.slice(0, 4).map((t) => (
          <span class="rounded-[var(--border-radius-sm)] bg-[var(--tag-bg)] px-2 py-0.5 text-xs text-[var(--tag-text)]">
            {t}
          </span>
        ))
      }
    </div>
  </div>
</article>
