---
import Layout from "../../layouts/Layout.astro";
import "../../styles/prose.css";
import TechIcon from "../../components/ui/TechIcon.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { projects } from "../../data/projects.ts";

export async function getStaticPaths() {
  const stories = await getCollection("projectStory");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: {
      project,
      story:
        stories.find(
          (s) => s.id.toLowerCase() === project.slug.toLowerCase(),
        ) ?? null,
    },
  }));
}

const { project, story } = Astro.props;
const StoryContent = story ? (await render(story)).Content : null;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const absoluteCover = new URL(project.cover.src, Astro.site).href;

// Map a display tech name to its icon filename (without .svg).
// Most names match the asset filename 1:1; these don't.
const iconOverrides: Record<string, string> = {
  PostgreSQL: "PostgresSQL",
  "React Native": "React",
};
const iconFor = (tech: string) => iconOverrides[tech] ?? tech;

// Previous / next project for bottom navigation (wraps around).
const index = projects.findIndex((p) => p.slug === project.slug);
const prev = projects[(index - 1 + projects.length) % projects.length];
const next = projects[(index + 1) % projects.length];

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.title,
  description: project.tagline,
  image: absoluteCover,
  url: canonical,
  creator: {
    "@type": "Person",
    name: "Sandeep Singh",
    url: Astro.site?.href.replace(/\/$/, ""),
  },
  keywords: project.tech.join(", "),
  genre: project.category,
  sameAs: [project.liveUrl, project.githubUrl].filter(Boolean),
};
---

<Layout
  title={`${project.title} — Sandeep Singh`}
  description={project.tagline}
  image={project.cover.src}
  imageWidth={1200}
  imageHeight={675}
  keywords={[project.title, project.category, ...project.tech]}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(projectSchema)}
  />
  <article class="border-b border-[var(--border)]">
    <div class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24">
      <a
        href="/projects"
        class="link-arrow group inline-flex items-center gap-1.5 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)]"
      >
        <span
          class="transition-transform duration-200 group-hover:-translate-x-1"
          aria-hidden="true">&larr;</span
        >
        All projects
      </a>

      <!-- The project header, showing category, title, and tagline. -->
      <header class="mt-8">
        <span
          class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
        >
          {project.category}
        </span>

        <h1
          class="mt-3 font-serif text-3xl md:text-4xl leading-tight tracking-tight text-[var(--text-1)]"
        >
          {project.title}
        </h1>

        <p
          class="mt-4 max-w-2xl text-base text-[var(--text-2)] leading-[var(--leading-relaxed)]"
        >
          {project.tagline}
        </p>

        <div class="mt-6 flex flex-wrap items-center gap-3">
          {
            project.liveUrl && (
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-[var(--border-radius-sm)] bg-[var(--accent)] px-4 py-2 text-sm text-[var(--bg)]! transition-colors duration-200 hover:bg-[var(--accent-hover)]"
              >
                Visit live site
                <span aria-hidden="true">&rarr;</span>
              </a>
            )
          }
          {
            project.githubUrl && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-[var(--border-radius-sm)] border border-[var(--border-strong)] px-4 py-2 text-sm text-[var(--text-1)]! transition-colors duration-200 hover:border-[var(--accent)] hover:text-[var(--accent)]!"
              >
                View source
              </a>
            )
          }
        </div>
      </header>

      <!-- The project cover image, optimized by Astro's built-in Image component. -->
      <Image
        src={project.cover}
        alt={project.title}
        width={1200}
        height={675}
        class="mt-10 aspect-[16/9] w-full rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] object-cover"
      />

      <!-- The project story, rendered from Markdown by Astro's content collections. -->
      <section class="mt-12">
        {
          story?.data.intro && (
            <p class="max-w-2xl text-lg text-[var(--text-1)] leading-[var(--leading-relaxed)]">
              {story.data.intro}
            </p>
          )
        }

        {
          StoryContent && (
            <div class="prose mt-8">
              <StoryContent />
            </div>
          )
        }

        <!-- Built with -->
        <h2
          class="mt-12 text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
        >
          Built with
        </h2>
        <div class="mt-5 flex flex-wrap gap-x-8 gap-y-6">
          {
            project.tech.map((tech) => (
              <TechIcon name={tech} icon={iconFor(tech)} />
            ))
          }
        </div>
      </section>

      <nav
        class="mt-16 grid grid-cols-1 gap-4 border-t border-[var(--border-subtle)] pt-8 sm:grid-cols-2"
        aria-label="More projects"
      >
        <a
          href={`/projects/${prev.slug}`}
          class="group flex flex-col gap-1.5 rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] p-5 transition-colors duration-200 hover:border-[var(--border-strong)]"
        >
          <span
            class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
          >
            &larr; Previous
          </span>
          <span
            class="font-serif text-lg leading-snug text-[var(--text-1)]! transition-colors duration-200 group-hover:text-[var(--accent)]!"
          >
            {prev.title}
          </span>
        </a>
        <a
          href={`/projects/${next.slug}`}
          class="group flex flex-col gap-1.5 rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] p-5 text-right transition-colors duration-200 hover:border-[var(--border-strong)] sm:items-end"
        >
          <span
            class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
          >
            Next &rarr;
          </span>
          <span
            class="font-serif text-lg leading-snug text-[var(--text-1)]! transition-colors duration-200 group-hover:text-[var(--accent)]!"
          >
            {next.title}
          </span>
        </a>
      </nav>
    </div>
  </article>
</Layout>
