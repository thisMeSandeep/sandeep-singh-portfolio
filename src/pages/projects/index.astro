---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ui/ProjectCard.astro";
import { projects } from "../../data/projects.ts";

const site = Astro.site?.href.replace(/\/$/, "") ?? "";
const projectsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Projects by Sandeep Singh",
  description:
    "Selected projects by Sandeep Singh across SaaS platforms, mobile apps, APIs, and dashboards.",
  url: `${site}/projects/`,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: projects.map((project, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${site}/projects/${project.slug}/`,
      name: project.title,
      description: project.tagline,
    })),
  },
};
---

<Layout
  title="Projects — Sandeep Singh"
  description="Selected projects by Sandeep Singh — SaaS platforms, mobile apps, and APIs built with React, TypeScript, Node.js, and more."
  keywords={["Sandeep Singh projects", "full-stack projects", "React projects", "Node.js projects", "portfolio"]}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(projectsSchema)}
  />
  <section class="border-b border-[var(--border)]">
      <div class="mx-auto max-w-[var(--max-w-wide)] px-6 md:px-8 py-24">
        <span
          class="text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]"
        >
          Featured Work
        </span>

        <h1
          class="mt-3 font-serif text-3xl leading-tight tracking-tight text-[var(--text-1)]"
        >
          All projects
        </h1>

        <p class="mt-3 max-w-xl text-sm text-[var(--text-2)] leading-[var(--leading-normal)]">
          A collection of things I've designed and built — from full SaaS
          platforms to focused tools and APIs.
        </p>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            projects.map((project) => (
              <div class="h-[26rem]">
                <ProjectCard
                  title={project.title}
                  tagline={project.tagline}
                  category={project.category}
                  cover={project.cover}
                  tech={project.tech}
                  liveUrl={project.liveUrl}
                  githubUrl={project.githubUrl}
                  slug={project.slug}
                  bentoSize={project.bentoSize as "large" | "medium" | "small"}
                />
              </div>
            ))
          }
        </div>
      </div>
  </section>
</Layout>
