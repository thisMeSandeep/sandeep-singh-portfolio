---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Skills from '../components/sections/Skills.astro';
import Experience from '../components/sections/Experience.astro';
import Projects from '../components/sections/Projects.astro';
import Freelance from '../components/sections/Freelance.astro';
import Blog from '../components/sections/Blog.astro';
import Contact from '../components/sections/Contact.astro';
import { linkedin, twitter, github, location, email } from '../data/info.ts';

const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const sameAs = [linkedin, twitter, github];

// Schema helps search engines connect the homepage, owner, and social profiles.
const homeSchema = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			'@id': `${site}/#website`,
			name: 'Sandeep Singh',
			url: site,
			inLanguage: 'en-US',
			publisher: { '@id': `${site}/#person` },
		},
		{
			'@type': 'Person',
			'@id': `${site}/#person`,
			name: 'Sandeep Singh',
			url: site,
			email: email.replace('mailto:', ''),
			jobTitle: 'Full-Stack Developer',
			image: `${site}/og.png`,
			address: {
				'@type': 'PostalAddress',
				addressLocality: location,
			},
			sameAs,
		},
	],
};
---

<Layout keywords={["Sandeep Singh", "full-stack developer", "React developer", "Node.js developer", "Astro portfolio"]}>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(homeSchema)}
	/>
	<Hero />
	<About />
	<Skills />
	<Experience />
	<Projects />
	<Freelance />
	<Blog />
	<Contact />
</Layout>
