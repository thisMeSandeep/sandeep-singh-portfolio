---
import Layout from "../../layouts/Layout.astro";
import "../../styles/prose.css";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Share from "../../components/icons/Share.astro";


export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.publishedDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const absoluteCover = new URL(post.data.cover, Astro.site).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  image: absoluteCover,
  datePublished: post.data.publishedDate.toISOString(),
  dateModified: post.data.publishedDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Sandeep Singh",
    url: Astro.site?.href.replace(/\/$/, ""),
  },
  publisher: {
    "@type": "Person",
    name: "Sandeep Singh",
    url: Astro.site?.href.replace(/\/$/, ""),
  },
  keywords: post.data.tags.join(", "),
  articleSection: post.data.category,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
---

<Layout
  title={`${post.data.title} — Sandeep Singh`}
  description={post.data.excerpt}
  image={post.data.cover}
  imageWidth={1200}
  imageHeight={675}
  type="article"
  publishedDate={post.data.publishedDate}
  modifiedDate={post.data.publishedDate}
  keywords={post.data.tags}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />
  <article class="border-b border-[var(--border)]">
      <div class="mx-auto max-w-[var(--max-w-prose,42rem)] px-6 md:px-8 py-24">
        <div class="flex items-center justify-between gap-4">
          <a
            href="/blogs"
            class="link-arrow group inline-flex items-center gap-1.5 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)]"
          >
            <span
              class="transition-transform duration-200 group-hover:-translate-x-1"
              aria-hidden="true">&larr;</span
            >
            All articles
          </a>
          <button
            type="button"
            data-share-button
            data-share-title={post.data.title}
            data-share-text={post.data.excerpt}
            aria-label="Share this article"
            class="share-button inline-flex items-center gap-1.5 rounded-[var(--border-radius-md)] border border-[var(--border)] px-3 py-1.5 text-sm text-[var(--text-2)] transition duration-200 hover:text-[var(--text-1)] hover:border-[var(--text-3)] hover:scale-105"
          >
            <Share />
            <span data-share-label>Share</span>
          </button>
        </div>

        <!-- The article header, showing category, date, read time, title, excerpt, and tags. -->
        <header class="mt-8">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]">
            <span>{post.data.category}</span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={post.data.publishedDate.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">&middot;</span>
            <span>{post.data.readTime} min read</span>
          </div>

          <h1
            class="mt-4 font-serif text-3xl md:text-4xl leading-tight tracking-tight text-[var(--text-1)]"
          >
            {post.data.title}
          </h1>

          <p class="mt-4 text-base text-[var(--text-2)] leading-[var(--leading-relaxed)]">
            {post.data.excerpt}
          </p>

          {
            post.data.tags.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-[var(--border-radius-sm)] bg-[var(--tag-bg)] px-2 py-0.5 text-xs text-[var(--tag-text)]">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
        </header>

        <!-- The cover image, optimized by Astro's built-in Image component. -->
        <Image
          src={post.data.cover}
          alt={post.data.title}
          width={1200}
          height={675}
          class="mt-10 aspect-[16/9] w-full rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] object-cover"
        />
        
        <!-- The actual blog content, rendered from Markdown by Astro's content collections. -->
        <div class="prose mt-10">
          <Content />
        </div>
      </div>
  </article>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-share-button]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const url = window.location.href;
        const title = btn.dataset.shareTitle ?? document.title;
        const text = btn.dataset.shareText ?? "";
        const label = btn.querySelector<HTMLElement>("[data-share-label]");

        if (navigator.share) {
          try {
            await navigator.share({ title, text, url });
            return;
          } catch {
            // user dismissed; fall through to clipboard
          }
        }
        try {
          await navigator.clipboard.writeText(url);
          if (label) {
            const original = label.textContent;
            label.textContent = "Link copied";
            setTimeout(() => {
              label.textContent = original;
            }, 1800);
          }
        } catch {
          window.prompt("Copy this link:", url);
        }
      });
    });
  </script>
</Layout>

<style>
  /* Prose/markdown styling lives in ../../styles/prose.css (imported above).
     Only page-specific styles remain here. */
  .share-button :global(svg) {
    width: 16px;
    height: 16px;
  }
</style>
