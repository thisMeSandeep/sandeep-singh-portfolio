---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.publishedDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${post.data.title} — Sandeep Singh`} description={post.data.excerpt}>
  <article class="border-b border-[var(--border)]">
      <div class="mx-auto max-w-[var(--max-w-prose,42rem)] px-6 md:px-8 py-24">
        <a
          href="/blogs"
          class="link-arrow group inline-flex items-center gap-1.5 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)]"
        >
          <span
            class="transition-transform duration-200 group-hover:-translate-x-1"
            aria-hidden="true">&larr;</span
          >
          All articles
        </a>

        <header class="mt-8">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs uppercase tracking-[var(--tracking-wider)] text-[var(--text-3)]">
            <span>{post.data.category}</span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={post.data.publishedDate.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">&middot;</span>
            <span>{post.data.readTime} min read</span>
          </div>

          <h1
            class="mt-4 font-serif text-3xl md:text-4xl leading-tight tracking-tight text-[var(--text-1)]"
          >
            {post.data.title}
          </h1>

          <p class="mt-4 text-base text-[var(--text-2)] leading-[var(--leading-relaxed)]">
            {post.data.excerpt}
          </p>

          {
            post.data.tags.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="rounded-[var(--border-radius-sm)] bg-[var(--tag-bg)] px-2 py-0.5 text-xs text-[var(--tag-text)]">
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
        </header>

        <Image
          src={post.data.cover}
          alt={post.data.title}
          width={1200}
          height={675}
          class="mt-10 aspect-[16/9] w-full rounded-[var(--border-radius-lg)] border border-[var(--border-subtle)] object-cover"
        />

        <div class="prose mt-10">
          <Content />
        </div>
      </div>
  </article>
</Layout>

<style>
  /* Markdown prose styling. Elements come from <Content />, so they aren't
     scoped by Astro — target them with :global() under the .prose wrapper.
     All colors use theme tokens, so light/dark switching is automatic. */
  .prose {
    color: var(--text-2);
    font-size: 1rem;
    line-height: var(--leading-relaxed);
  }

  /* Headings */
  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1.25;
    letter-spacing: var(--tracking-tight);
    color: var(--text-1);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: var(--font-weight-medium);
    line-height: 1.35;
    color: var(--text-1);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(h4) {
    font-size: 1.05rem;
    font-weight: var(--font-weight-medium);
    color: var(--text-1);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose :global(:is(h2, h3, h4):first-child) {
    margin-top: 0;
  }

  /* Paragraphs & inline emphasis */
  .prose :global(p) {
    margin: 1rem 0;
  }
  .prose :global(strong) {
    color: var(--text-1);
    font-weight: var(--font-weight-medium);
  }

  /* Links */
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition);
  }
  .prose :global(a:hover) {
    color: var(--accent-hover);
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(li) {
    margin: 0.375rem 0;
  }
  .prose :global(li::marker) {
    color: var(--text-3);
  }
  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin: 0.375rem 0;
  }

  /* Blockquotes */
  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    border-left: 3px solid var(--accent);
    color: var(--text-1);
    font-style: italic;
  }
  .prose :global(blockquote p) {
    margin: 0.5rem 0;
  }

  /* Thin divider (---) */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Images */
  .prose :global(img) {
    display: block;
    width: 100%;
    margin: 1.5rem 0;
    border: 1px solid var(--border-subtle);
    border-radius: var(--border-radius-lg);
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-3);
    color: var(--text-1);
    font-weight: var(--font-weight-medium);
  }

  /* Inline code */
  .prose :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
    background: var(--bg-3);
    color: var(--text-1);
    padding: 0.125rem 0.375rem;
    border-radius: var(--border-radius-sm);
  }

  /* Fenced code blocks (Shiki adds .astro-code + inline bg/token colors) */
  .prose :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: var(--border-radius-lg);
    border: 1px solid var(--border-subtle);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
</style>
